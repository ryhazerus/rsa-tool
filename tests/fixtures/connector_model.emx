<?xml version="1.0" encoding="UTF-8"?>
<!--
  A Component with two parts and a Connector between them.
  ECU has parts: sensorPart (of type Sensor) and actuatorPart (of type Actuator).
  The connector "link1" joins sensorPart → actuatorPart.
-->
<uml:Model xmi:version="2.1"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:uml="http://www.eclipse.org/uml2/3.0.0/UML"
    xmi:id="_modelC" name="ConnectorModel">

  <packagedElement xmi:type="uml:Class" xmi:id="_sensor"   name="Sensor"/>
  <packagedElement xmi:type="uml:Class" xmi:id="_actuator" name="Actuator"/>
  <packagedElement xmi:type="uml:Class" xmi:id="_logger"   name="Logger"/>

  <packagedElement xmi:type="uml:Component" xmi:id="_ecu" name="ECU">

    <!-- Parts -->
    <ownedAttribute xmi:type="uml:Property" xmi:id="_partSensor"   name="sensorPart"   type="_sensor"/>
    <ownedAttribute xmi:type="uml:Property" xmi:id="_partActuator" name="actuatorPart" type="_actuator"/>
    <ownedAttribute xmi:type="uml:Property" xmi:id="_partLogger"   name="loggerPart"   type="_logger"/>

    <!-- Connector: link1 joins sensorPart and actuatorPart -->
    <ownedConnector xmi:type="uml:Connector" xmi:id="_conn1" name="link1">
      <end xmi:type="uml:ConnectorEnd" xmi:id="_end1a" role="_partSensor"/>
      <end xmi:type="uml:ConnectorEnd" xmi:id="_end1b" role="_partActuator"/>
    </ownedConnector>

  </packagedElement>

</uml:Model>
